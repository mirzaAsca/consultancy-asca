{
  "name": "linkedin-investor-scout",
  "private": true,
  "version": "1.0.0",
  "description": "Chrome MV3 extension that scans LinkedIn profile URLs to detect connection level and highlights prospects in-feed.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "icons": "python3 scripts/generate-icons.py",
    "zip": "bun run build && rm -f linkedin-investor-scout.zip && cd dist && zip -r ../linkedin-investor-scout.zip . -x '.vite/*' '*.map' && cd .. && echo 'wrote' $(du -h linkedin-investor-scout.zip | cut -f1) 'linkedin-investor-scout.zip'"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.33",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.2.1",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
